# UnrealBench Environment Configuration
# Copy this file to .env and fill in your API keys

# ============================================
# API Keys (Required - depends on agent used)
# ============================================

# For claude-code agent subscription auth (preferred)
# Run `claude /login` locally, or generate a long-lived token with:
#   claude setup-token
#   export CLAUDE_CODE_OAUTH_TOKEN=your_token_here
# Benchmark Claude runtime paths always prefer subscription auth.
# ANTHROPIC_API_KEY below is not used by the benchmark runtime, but may still be
# used by separate authoring or pipeline utilities in this repo.
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# For codex agent and some openhands models
OPENAI_API_KEY=your_openai_api_key_here

# For GLM-5.2 through Z.ai DevPack / Coding Plan.
# The qwen-code solver maps ZAI_API_KEY to Qwen Code OpenAI-compatible auth
# automatically when --model glm-5.2 is used.
ZAI_API_KEY=your_zai_coding_plan_key_here
ZAI_API_BASE_URL=https://api.z.ai/api/coding/paas/v4

# For gemini-cli agent
GEMINI_API_KEY=your_gemini_api_key_here
# Alternative variable name (either works)
# GOOGLE_API_KEY=your_google_api_key_here

# For openhands agent (via OpenRouter)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# For openhands agent (via Fireworks)
FIREWORKS_API_KEY=your_fireworks_api_key_here

# ============================================
# Optional Configuration
# ============================================

# OpenRouter configuration (optional for openhands)
OPENROUTER_API_BASE=https://openrouter.ai/api/v1
OR_SITE_URL=your_site_url
OR_APP_NAME=your_app_name

# Godot configuration (optional)
# Path to Godot executable if not in PATH
# GODOT_EXEC_PATH=godot

# MCP Server configuration (macOS only)
# Display number for screenshot capture (default: 2)
# Run "system_profiler SPDisplaysDataType" to find your display number
GODOT_SCREENSHOT_DISPLAY=2


# Terminal coding-agent CLIs used by the full model matrix manifest.
# Set *_CMD when the executable is not on PATH. Set *_ARGS for non-interactive
# approval flags required by your installed CLI.
QWEN_CODE_CMD=qwen
# Leave QWEN_CODE_ARGS unset to let glm-5.2 auto-use ZAI_API_KEY and the Z.ai
# Coding Plan endpoint. Set this only when you need custom Qwen Code flags.
# QWEN_CODE_ARGS=--yolo
KIMI_CODE_CMD=kimi
KIMI_CODE_ARGS=
DEEPSEEK_CODE_CMD=deepseek
DEEPSEEK_CODE_ARGS=
GLM_CODE_CMD=glm
GLM_CODE_ARGS=
MUSE_CODE_CMD=muse
MUSE_CODE_ARGS=

# Optional benchmark pricing overrides, USD per 1M tokens. These override the
# built-in estimate table and accept either UnrealBench keys
# (input/output/cache_read) or Qwen Code keys
# (inputPerMillionTokens/outputPerMillionTokens/cacheReadPerMillionTokens).
# UNREALBENCH_MODEL_PRICING_FILE=C:/path/to/model_pricing.json
# UNREALBENCH_MODEL_PRICING_JSON={"qwen3.7-plus":{"input":0.30,"output":1.20,"cache_read":0.06}}

