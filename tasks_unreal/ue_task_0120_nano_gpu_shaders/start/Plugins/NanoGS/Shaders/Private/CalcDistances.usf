#include "/Engine/Public/Platform.ush"
RWStructuredBuffer<uint> DistanceBuffer; RWStructuredBuffer<uint> KeyBuffer; uint SplatCount;
[numthreads(256,1,1)] void MainCS(uint3 DispatchThreadId : SV_DispatchThreadID) { if (DispatchThreadId.x < SplatCount) { DistanceBuffer[DispatchThreadId.x] = 0; KeyBuffer[DispatchThreadId.x] = DispatchThreadId.x; } }
