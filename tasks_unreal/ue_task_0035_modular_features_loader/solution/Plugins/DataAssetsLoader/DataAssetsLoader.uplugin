{
	"FileVersion": 3,
	"Version": 1,
	"VersionName": "1.0",
	"FriendlyName": "Data Assets Loader",
	"Description": "Utilizes Asset Registry to automatically load and register data assets on load asynchronously, no manual storing needed, enabling consumers to obtain or listen any data asset by class with no extra setup",
	"Category": "Programming",
	"CreatedBy": "Yevhenii Selivanov",
	"DocsURL": "",
