struct ALSXT_API FAlsxtLocomotionModeGameplayCameraOffsetSettings
{
	GENERATED_BODY()

	UPROPERTY(EditAnywhere, BlueprintReadWrite, meta = (Categories = "Als.LocomotionMode"))
